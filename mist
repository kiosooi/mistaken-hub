-- HIGHLIGHT + BILLBOARD HELPERS
------------------------------------------------------------
local function applyHighlight(obj, color)
    if not obj:FindFirstChild("ESP_HIGHLIGHT") then
        local h = Instance.new("Highlight")
        h.Name = "ESP_HIGHLIGHT"
        h.FillColor = color
        h.FillTransparency = 0.4
        h.OutlineColor = color
        h.Parent = obj
    end
end

local function removeHighlight(obj)
    if obj:FindFirstChild("ESP_HIGHLIGHT") then
        obj.ESP_HIGHLIGHT:Destroy()
    end
    if obj:FindFirstChild("ESP_BILLBOARD") then
        obj.ESP_BILLBOARD:Destroy()
    end
end

local function applyBillboard(obj, text)
    if obj:FindFirstChild("ESP_BILLBOARD") then
        obj.ESP_BILLBOARD.TextLabel.Text = text
        return
    end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_BILLBOARD"
    billboard.Size = UDim2.new(0,70,0,25)
    billboard.Adornee = obj
    billboard.AlwaysOnTop = true

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.TextStrokeTransparency = 0
    label.TextScaled = false
    label.TextSize = 16
    label.Text = text
    label.Parent = billboard

    billboard.Parent = obj
end

