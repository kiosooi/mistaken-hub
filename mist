local AutoFarm = false
local player = game.Players.LocalPlayer

local Section = PlayerTab:CreateSection("Auto Farm")

PlayerTab:CreateToggle({
   Name = "Auto Farm",
   CurrentValue = false,
   Callback = function(Value)
      AutoFarm = Value

      task.spawn(function()
         while AutoFarm do

            local myCharacter = nil
            local survivors = workspace:WaitForChild("Players"):WaitForChild("Survivors")

            -- find the survivor model that belongs to the LocalPlayer
            for _, model in pairs(survivors:GetChildren()) do
               if model:GetAttribute("Username") == player.Name then
                  myCharacter = model
                  break
               end
            end

            if myCharacter then
               local hrp = myCharacter:FindFirstChild("HumanoidRootPart")

               if hrp then
                  local mapFolder = workspace:WaitForChild("Map")
                     :WaitForChild("Ingame")
                     :WaitForChild("Map")

                  for _, gen in pairs(mapFolder:GetChildren()) do
                     if not AutoFarm then break end

                     if gen:IsA("Model") and gen.Name == "Generator" then
                        local progress = gen:FindFirstChild("Progress")

                        if progress and progress.Value < 100 then

                           if gen.PrimaryPart then
                              hrp.CFrame = gen.PrimaryPart.CFrame * CFrame.new(0,0,-3)
                           end

                           task.wait(0.2)

                           -- enter generator
                           gen.Remotes.RF:InvokeServer("enter")

                           task.wait(0.2)

                           -- repair
                           if gen.Remotes:FindFirstChild("RE") then
                              gen.Remotes.RE:FireServer()
                           end

                           task.wait(0.2)

                           -- leave generator
                           gen.Remotes.RF:InvokeServer("leave")

                           task.wait(0.2)
                        end
                     end
                  end
               end
            end

            task.wait(0.2)
         end
      end)
   end,
})

