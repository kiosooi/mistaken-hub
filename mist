                    targetModel = model
                    break
                end
            end
        end

        if not targetModel then continue end

        local speedFolder = targetModel:FindFirstChild("SpeedMultipliers")
        if not speedFolder then continue end

        local existing = speedFolder:FindFirstChild("SpeedStatus")

        if someoneClose then
            -- remove boost if someone is nearby
            if existing then
                existing:Destroy()
            end
        else
            -- create boost if nobody nearby
            if not existing then
                local val = Instance.new("NumberValue")
                val.Name = "SpeedStatus"
                val.Value = 1.3
                val.Parent = speedFolder
            end
        end
    end
end)
